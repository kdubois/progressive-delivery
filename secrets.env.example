# Kubernetes Agent Secrets Configuration
# Copy this file to secrets.env and fill in your actual values
# OR use generate-secrets.sh to create it from environment variables
# secrets.env is git-ignored for security

# OpenAI API Key (for qwen3-14b - used by DiagnosticAgent and AnalysisAgent)
OPENAI_API_KEY=sk-your-openai-key-here

# Remediation API Key (used by RemediationAgent only)
# This uses a potentially more capable model for code fixes
# If not set, will use OPENAI_API_KEY
REM_API_KEY=sk-your-remediation-key-here

# Gemini API Key (if using Gemini profile)
GOOGLE_API_KEY=your-google-api-key-here

# GitHub Token (for creating PRs and issues)
# Required - needs 'repo' scope
GITHUB_TOKEN=ghp_your-github-token-here

# Google Cloud Project (optional)
GOOGLE_CLOUD_PROJECT=your-project-id