apiVersion: v1
kind: Secret
metadata:
  name: kubernetes-agent
  namespace: openshift-gitops
type: Opaque
stringData:
  # OpenAI API Key (for qwen3-14b - used by DiagnosticAgent and AnalysisAgent)
  openai_api_key: ${OPENAI_API_KEY}
  
  # Remediation API Key (for GPT-4o-mini - used by RemediationAgent only)
  # This uses real OpenAI to avoid Qwen's JSON formatting issues
  rem_api_key: ${REM_API_KEY}
  
  # Gemini API Key (if using Gemini profile)
  google_api_key: ${GOOGLE_API_KEY}
  
  # GitHub Token (for creating PRs and issues)
  github_token: ${GITHUB_TOKEN}
  
  # Google Cloud Project (optional)
  google_cloud_project: "${GOOGLE_CLOUD_PROJECT}"