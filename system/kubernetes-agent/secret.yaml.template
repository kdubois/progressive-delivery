apiVersion: v1
kind: Secret
metadata:
  name: kubernetes-agent
  namespace: openshift-gitops
type: Opaque
stringData:
  # Analysis model API key (used by DiagnosticsAgent, AnalysisAgent, ScoringAgent)
  analysis_api_key: ${ANALYSIS_API_KEY}

  # Remediation model API key (used by RemediationAgent — defaults to analysis key if not set)
  remediation_api_key: ${REMEDIATION_API_KEY}

  # GitHub Token (for creating PRs and issues)
  github_token: ${GITHUB_TOKEN}
